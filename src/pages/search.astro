---
import BaseLayout from '../components/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="搜索 | 刘强的个人工作台" description="全文搜索文章和项目" currentPath="/search">
  <PageHero
    eyebrow="搜索"
    title="全文搜索站内内容"
    description="站内搜索会在构建后自动生成全文检索索引，搜索范围覆盖文章正文与项目页面。"
  />

  <section class="container panel search-panel">
    <div id="search"></div>
  </section>

  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  </Fragment>

  <Fragment slot="scripts">
    <script is:inline>
      window.addEventListener('DOMContentLoaded', async () => {
        if (!window.PagefindUI) {
          await import('/pagefind/pagefind-ui.js');
        }
        new window.PagefindUI({
          element: '#search',
          showSubResults: true,
          resetStyles: false,
          translations: {
            placeholder: '搜索文章标题、正文、项目和标签',
            clear_search: '清空',
            load_more: '加载更多',
            search_label: '全文搜索',
            zero_results: '没有找到相关内容',
            many_results: '找到 [COUNT] 条结果',
            one_result: '找到 1 条结果',
            searching: '搜索中',
          },
        });
      });
    </script>
  </Fragment>
</BaseLayout>

<style>
  .search-panel {
    margin-top: 24px;
    padding: 28px;
  }

  :global(.pagefind-ui) {
    --pagefind-ui-primary: #7f411b;
    --pagefind-ui-text: #24170e;
    --pagefind-ui-background: transparent;
    --pagefind-ui-border: rgba(93, 68, 38, 0.14);
    --pagefind-ui-tag: rgba(157, 95, 47, 0.1);
    font-family: 'Noto Sans SC', sans-serif;
  }

  :global(.pagefind-ui__search-input) {
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.7);
  }

  :global(.pagefind-ui__result) {
    padding: 18px 0;
    border-top: 1px solid rgba(93, 68, 38, 0.1);
  }
</style>
