---
import BaseLayout from '../../components/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getProjects } from '../../lib/content';

const projects = await getProjects();
---

<BaseLayout title="项目 | 刘强的个人工作台" description="项目与实验列表" currentPath="/projects">
  <section class="page-header panel">
    <span class="eyebrow">项目</span>
    <h1>项目记录</h1>
    <p>这里放的是产品、工具、工作流和站点实验。相比炫技，更看重长期可维护和真正可用。</p>
  </section>

  <section class="container project-grid">
    {projects.map((project) => <ProjectCard project={project} />)}
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: 22px 24px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    margin: 12px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 4vw, 2.6rem);
    line-height: 1.25;
  }

  .page-header p {
    margin: 14px 0 0;
    color: var(--text-soft);
    line-height: 1.85;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
