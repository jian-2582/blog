---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getProjects } from '../../lib/content';

const projects = await getProjects();
---

<BaseLayout title="项目 | 刘强 | usgpt.us" description="项目与实验列表" currentPath="/projects">
  <PageHero
    eyebrow="项目"
    title="把写下来的思考，再做成真实可用的东西"
    description="这里放的是产品、工具、工作流和站点实验。相比炫技，更看重长期可维护和真正可用。"
    aside={[
      { label: '项目总数', value: `${projects.length} 个` },
      { label: '更新方式', value: '持续维护' },
    ]}
  />

  <section class="container project-grid">
    {projects.map((project) => <ProjectCard project={project} />)}
  </section>
</BaseLayout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
