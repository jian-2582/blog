---
import BaseLayout from '../../components/BaseLayout.astro';
import { getAllTags, getFeaturedPosts, getPublishedPosts, getTagCountMap } from '../../lib/content';
import { slugifyTag } from '../../lib/format';

const posts = await getPublishedPosts();
const featuredPosts = await getFeaturedPosts(3);
const tags = getAllTags(posts);
const tagCounts = getTagCountMap(posts);
---

<BaseLayout title="文章 | 刘强的个人工作台" description="文章归档与专题索引" currentPath="/blog">
  <section class="blog-layout">
    <aside class="blog-sidebar">
      <section class="panel side-card">
        <h2>文章索引</h2>
        <div class="side-links">
          <a href="/blog">全部文章</a>
          <a href="/archive">年份归档</a>
          <a href="/search">站内搜索</a>
        </div>
      </section>

      <section class="panel side-card">
        <h2>热门标签</h2>
        <div class="tag-cloud">
          {tags.slice(0, 12).map((tag) => (
            <a class="chip" href={`/tags/${slugifyTag(tag)}/`}>
              {tag}
              <small>{tagCounts[tag]}</small>
            </a>
          ))}
        </div>
      </section>
    </aside>

    <section class="blog-main">
      <header class="panel list-header">
        <span class="eyebrow">文章列表</span>
        <h1>文章归档与专题索引</h1>
        <p>这里把长期写作的内容按主题和时间组织起来。阅读页保持安静，列表页则更强调秩序与查找效率。</p>
      </header>

      <div class="section-bar">
        <h2>精选文章</h2>
        <a href="/archive">查看归档</a>
      </div>

      <div class="blog-feed">
        {posts.map((post) => (
          <article class="panel list-item">
            <div class="meta-row">
              <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
              <span>{post.data.tags.join(' / ')}</span>
            </div>
            <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
            <div class="chips">
              {post.data.featured && <span class="chip">精选</span>}
              {post.data.tags.slice(0, 2).map((tag) => (
                <span class="chip">{tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <aside class="blog-right">
      <section class="panel side-card">
        <h2>推荐阅读</h2>
        <div class="recommended-list">
          {featuredPosts.map((post) => (
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          ))}
        </div>
      </section>

      <section class="panel side-card">
        <h2>阅读提示</h2>
        <div class="topic-list">
          <span>文章详情页会保留目录与相关文章。</span>
          <span>标签页适合按专题集中阅读。</span>
          <span>站内搜索适合快速找旧文章。</span>
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>

<style>
  .blog-layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr) 260px;
    gap: 20px;
    align-items: start;
  }

  .blog-sidebar,
  .blog-right {
    display: grid;
    gap: 16px;
  }

  .side-card {
    padding: 18px;
  }

  .side-card h2 {
    margin: 0 0 14px;
    font-size: 1rem;
  }

  .side-links,
  .recommended-list,
  .topic-list {
    display: grid;
    gap: 12px;
  }

  .side-links a,
  .recommended-list a {
    color: var(--text-soft);
    line-height: 1.75;
  }

  .side-links a:hover,
  .recommended-list a:hover {
    color: var(--accent);
  }

  .topic-list span {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-cloud small {
    opacity: 0.72;
  }

  .list-header {
    padding: 22px 24px;
    margin-bottom: 16px;
  }

  .list-header h1 {
    margin: 12px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 4vw, 2.7rem);
    line-height: 1.25;
  }

  .list-header p {
    margin: 14px 0 0;
    color: var(--text-soft);
    line-height: 1.85;
  }

  .section-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-bar h2 {
    margin: 0;
    font-size: 1.08rem;
  }

  .section-bar a {
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 600;
  }

  .blog-feed {
    display: grid;
    gap: 14px;
  }

  .list-item {
    padding: 18px 20px;
  }

  .list-item h3 {
    margin: 12px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: 1.42rem;
    line-height: 1.4;
  }

  .list-item p {
    margin: 12px 0 0;
    color: var(--text-soft);
    line-height: 1.84;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  @media (max-width: 1100px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      order: 2;
    }

    .blog-main {
      order: 1;
    }

    .blog-right {
      order: 3;
    }
  }
</style>
