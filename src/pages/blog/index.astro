---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags, getPublishedPosts, getTagCountMap } from '../../lib/content';
import { slugifyTag } from '../../lib/format';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
const tagCounts = getTagCountMap(posts);
---

<BaseLayout title="博客 | 刘强的博客" description="所有文章与标签索引" currentPath="/blog">
  <PageHero
    eyebrow="博客"
    title="文章归档与标签索引"
    description="所有内容都围绕一个原则展开：尽量把经验写成别人明天就能复用的东西。"
    aside={[
      { label: '文章总数', value: `${posts.length} 篇` },
      { label: '标签数量', value: `${tags.length} 个` },
    ]}
  />

  <section class="container section-block">
    <div class="tag-cloud panel">
      {tags.map((tag) => (
        <a class="chip" href={`/tags/${slugifyTag(tag)}/`}>
          #{tag}
          <small>{tagCounts[tag]}</small>
        </a>
      ))}
    </div>
  </section>

  <section class="container post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .section-block {
    margin-top: 24px;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding: 24px;
  }

  .tag-cloud small {
    opacity: 0.7;
  }

  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
