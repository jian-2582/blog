---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getPublishedPosts, getRelatedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, posts } }));
}

const { post, posts } = Astro.props;
const { Content } = await render(post);
const relatedPosts = getRelatedPosts(posts, post.id, post.data.tags);
---

<PostLayout entry={post} relatedPosts={relatedPosts}>
  <Content />
</PostLayout>
