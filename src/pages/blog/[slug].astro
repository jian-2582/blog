---
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getPublishedPosts, getRelatedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post, posts } }));
}

const { post, posts } = Astro.props;
const { Content, headings } = await render(post);
const relatedPosts = getRelatedPosts(posts, post.id, post.data.tags);
const currentIndex = posts.findIndex((entry) => entry.id === post.id);
const previousPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
---

<PostLayout
  entry={post}
  relatedPosts={relatedPosts}
  headings={headings}
  previousPost={previousPost}
  nextPost={nextPost}
>
  <Content />
</PostLayout>
