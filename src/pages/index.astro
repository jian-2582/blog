---
import BaseLayout from '../components/BaseLayout.astro';
import NewsletterBanner from '../components/NewsletterBanner.astro';
import PageHero from '../components/PageHero.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getFeaturedPosts, getFeaturedProjects, getPublishedPosts } from '../lib/content';
import { homeSections, metrics, siteConfig } from '../data/site';

const featuredPosts = await getFeaturedPosts();
const latestPosts = (await getPublishedPosts()).slice(0, 4);
const featuredProjects = await getFeaturedProjects();
---

<BaseLayout>
  <PageHero
    eyebrow="usgpt.us"
    title="把 AI 工具、自动化和个人网站，做成一套长期在线的工作台"
    description={siteConfig.intro}
    actions={[
      { href: '/blog', label: '查看文章' },
      { href: '/projects', label: '看项目', variant: 'secondary' },
    ]}
    aside={metrics}
  />

  <section class="container home-grid">
    <div class="home-intro grid">
      {homeSections.map((item) => (
        <article class="panel feature-card">
          <span class="eyebrow">{item.eyebrow}</span>
          <h2>{item.title}</h2>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container section-block">
    <span class="eyebrow">精选文章</span>
    <div class="section-head">
      <div>
        <h2 class="section-title">先从这几篇开始认识这座站</h2>
        <p class="section-copy">这些文章更接近我正在反复做、也愿意长期写下去的主题。</p>
      </div>
      <a class="button button-secondary" href="/blog">查看全部文章</a>
    </div>
    <div class="post-grid">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  <section class="container section-block">
    <span class="eyebrow">项目</span>
    <div class="section-head">
      <div>
        <h2 class="section-title">文章之外，我也会把东西真正做出来</h2>
        <p class="section-copy">这里放的是站点、脚本、工具和工作流实验，不是只停在想法层。</p>
      </div>
      <a class="button button-secondary" href="/projects">浏览项目</a>
    </div>
    <div class="project-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="container section-block">
    <span class="eyebrow">最近更新</span>
    <div class="timeline panel">
      {latestPosts.map((post) => (
        <a href={`/blog/${post.id}/`} class="timeline-item">
          <strong>{post.data.title}</strong>
          <span>{post.data.description}</span>
        </a>
      ))}
    </div>
  </section>

  <NewsletterBanner />
</BaseLayout>

<style>
  .home-grid,
  .section-block {
    margin-top: 26px;
  }

  .home-intro {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .feature-card {
    padding: 28px;
  }

  .feature-card h2 {
    margin: 0;
    font-family: 'Noto Serif SC', serif;
    font-size: 1.45rem;
    line-height: 1.4;
  }

  .feature-card p {
    margin: 14px 0 0;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .section-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 18px;
  }

  .post-grid,
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .timeline {
    display: grid;
    padding: 12px 24px;
  }

  .timeline-item {
    display: grid;
    gap: 8px;
    padding: 18px 0;
    border-top: 1px solid var(--line);
  }

  .timeline-item:first-child {
    border-top: 0;
  }

  .timeline-item span {
    color: var(--text-soft);
    line-height: 1.85;
  }

  @media (max-width: 960px) {
    .home-intro,
    .post-grid,
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
