---
import BaseLayout from '../components/BaseLayout.astro';
import { getAllTags, getFeaturedPosts, getFeaturedProjects, getPublishedPosts, getTagCountMap } from '../lib/content';
import { siteConfig } from '../data/site';
import { slugifyTag } from '../lib/format';

const posts = await getPublishedPosts();
const featuredPosts = await getFeaturedPosts(5);
const featuredLead = featuredPosts[0];
const featuredRest = featuredPosts.slice(1);
const latestPosts = posts.slice(0, 8);
const projects = await getFeaturedProjects(3);
const tags = getAllTags(posts).slice(0, 10);
const tagCounts = getTagCountMap(posts);
---

<BaseLayout>
  <section class="home-toolbar panel">
    <div class="toolbar-left">
      <a class="toolbar-pill is-active" href="/">推荐</a>
      <a class="toolbar-pill" href="/blog">最新文章</a>
      <a class="toolbar-pill" href="/archive">文章归档</a>
      <a class="toolbar-pill" href="/projects">项目记录</a>
    </div>
    <div class="toolbar-note">持续记录人工智能工具、自动化流程与个人网站实践</div>
  </section>

  <section class="home-layout">
    <aside class="left-column">
      <section class="panel side-card">
        <h2>站点导航</h2>
        <div class="side-links">
          <a href="/blog">全部文章</a>
          <a href="/projects">项目记录</a>
          <a href="/archive">年份归档</a>
          <a href="/about">关于作者</a>
          <a href="/search">站内搜索</a>
        </div>
      </section>

      <section class="panel side-card">
        <h2>关注主题</h2>
        <div class="topic-list">
          <span>人工智能工具的真实使用</span>
          <span>自动化流程与效率提升</span>
          <span>网站搭建与部署记录</span>
          <span>从想法到上线的项目过程</span>
        </div>
      </section>

      <section class="panel side-card">
        <h2>常用标签</h2>
        <div class="tag-cloud">
          {tags.map((tag) => (
            <a class="chip" href={`/tags/${slugifyTag(tag)}/`}>
              {tag}
              <small>{tagCounts[tag]}</small>
            </a>
          ))}
        </div>
      </section>
    </aside>

    <div class="main-column">
      <section class="panel featured-panel">
        <span class="eyebrow">推荐阅读</span>
        <h1>{featuredLead?.data.title ?? '欢迎来到这座站'}</h1>
        <p>{featuredLead?.data.description ?? siteConfig.intro}</p>
        {featuredLead && (
          <div class="featured-actions">
            <a class="button button-primary" href={`/blog/${featuredLead.id}/`}>继续阅读</a>
            <a class="button button-secondary" href="/blog">查看全部文章</a>
          </div>
        )}
      </section>

      <section class="feed-section">
        <div class="section-bar">
          <h2>精选文章</h2>
          <a href="/blog">更多文章</a>
        </div>

        <div class="post-feed">
          {featuredLead && (
            <article class="feed-item feed-item-large panel">
              <div class="meta-row">
                <span>{featuredLead.data.pubDate.toLocaleDateString('zh-CN')}</span>
                <span>{featuredLead.data.tags.join(' / ')}</span>
              </div>
              <h3><a href={`/blog/${featuredLead.id}/`}>{featuredLead.data.title}</a></h3>
              <p>{featuredLead.data.description}</p>
              <div class="chips">
                {featuredLead.data.tags.slice(0, 3).map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            </article>
          )}

          {featuredRest.map((post) => (
            <article class="feed-item panel">
              <div class="meta-row">
                <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
                <span>{post.data.tags.join(' / ')}</span>
              </div>
              <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="feed-section">
        <div class="section-bar">
          <h2>最近更新</h2>
          <a href="/archive">查看归档</a>
        </div>
        <div class="timeline panel">
          {latestPosts.map((post) => (
            <a href={`/blog/${post.id}/`} class="timeline-item">
              <strong>{post.data.title}</strong>
              <span>{post.data.description}</span>
              <small>{post.data.pubDate.toLocaleDateString('zh-CN')}</small>
            </a>
          ))}
        </div>
      </section>
    </div>

    <aside class="right-column">
      <section class="panel side-card author-card">
        <h2>关于作者</h2>
        <p>{siteConfig.intro}</p>
        <a class="button button-secondary" href="/about">了解更多</a>
      </section>

      <section class="panel side-card">
        <h2>项目动态</h2>
        <div class="project-list">
          {projects.map((project) => (
            <a href={`/projects/${project.id}/`}>
              <strong>{project.data.title}</strong>
              <span>{project.data.summary}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="panel side-card">
        <h2>订阅与联系</h2>
        <div class="side-links">
          <a href="/rss.xml">订阅更新</a>
          <a href="mailto:hi@usgpt.us">邮件联系</a>
          <a href="/search">站内搜索</a>
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>

<style>
  .home-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 14px 18px;
    margin-bottom: 18px;
    background: var(--panel-soft);
  }

  .toolbar-left {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .toolbar-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    color: var(--text-soft);
    font-size: 0.84rem;
    font-weight: 600;
  }

  .toolbar-pill.is-active,
  .toolbar-pill:hover {
    background: #fff;
    color: var(--accent);
  }

  .toolbar-note {
    color: var(--text-soft);
    font-size: 0.86rem;
  }

  .home-layout {
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr) 290px;
    gap: 20px;
    align-items: start;
  }

  .left-column,
  .right-column {
    display: grid;
    gap: 16px;
  }

  .side-card {
    padding: 18px;
  }

  .side-card h2 {
    margin: 0 0 14px;
    font-size: 1rem;
  }

  .side-links,
  .topic-list,
  .project-list {
    display: grid;
    gap: 12px;
  }

  .side-links a,
  .project-list a {
    color: var(--text-soft);
    line-height: 1.75;
  }

  .side-links a:hover,
  .project-list a:hover {
    color: var(--accent);
  }

  .topic-list span {
    color: var(--text-soft);
    line-height: 1.75;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-cloud small {
    opacity: 0.72;
  }

  .featured-panel {
    padding: 24px;
    margin-bottom: 18px;
  }

  .featured-panel h1 {
    margin: 14px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.25;
  }

  .featured-panel p {
    margin: 16px 0 0;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 18px;
  }

  .feed-section {
    margin-top: 18px;
  }

  .section-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
  }

  .section-bar h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .section-bar a {
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 600;
  }

  .post-feed {
    display: grid;
    gap: 14px;
  }

  .feed-item {
    padding: 18px 20px;
  }

  .feed-item h3 {
    margin: 12px 0 0;
    font-size: 1.45rem;
  }

  .feed-item p {
    margin: 12px 0 0;
    color: var(--text-soft);
    line-height: 1.84;
  }

  .feed-item-large h3 {
    font-size: 1.7rem;
  }

  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 14px;
  }

  .timeline {
    padding: 6px 20px;
  }

  .timeline-item {
    display: grid;
    gap: 8px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
  }

  .timeline-item:first-child {
    border-top: 0;
  }

  .timeline-item span,
  .timeline-item small {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .author-card p {
    margin: 0 0 14px;
    color: var(--text-soft);
    line-height: 1.85;
  }

  .project-list strong {
    display: block;
    margin-bottom: 6px;
    color: var(--text);
  }

  .project-list span {
    color: var(--text-soft);
    line-height: 1.75;
  }

  @media (max-width: 1100px) {
    .home-layout {
      grid-template-columns: 1fr;
    }

    .left-column {
      order: 2;
    }

    .main-column {
      order: 1;
    }

    .right-column {
      order: 3;
    }
  }
</style>
