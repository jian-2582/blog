---
import BaseLayout from '../../components/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags, getPublishedPosts } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return getAllTags(posts).map((tag) => ({
    params: { tag: tag.toLowerCase() },
    props: { tag },
  }));
}

const { tag } = Astro.props;
const posts = (await getPublishedPosts()).filter((post) => post.data.tags.includes(tag));
---

<BaseLayout title={`标签：${tag} | 刘强的博客`} description={`查看标签 ${tag} 下的所有文章`}>
  <PageHero
    eyebrow="标签页"
    title={`与「${tag}」相关的内容`}
    description="同一主题下的文章会持续累积，方便按专题阅读。"
    aside={[{ label: '文章数', value: `${posts.length} 篇` }]}
  />

  <section class="container post-grid">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 22px;
    margin-top: 24px;
  }

  @media (max-width: 900px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
