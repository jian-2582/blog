---
import BaseLayout from '../components/BaseLayout.astro';
import GiscusComments from '../components/GiscusComments.astro';
import type { CollectionEntry } from 'astro:content';
import { formatDate, slugifyTag } from '../lib/format';
import { getReadingMinutes } from '../lib/content';

interface Props {
  entry: CollectionEntry<'blog'>;
  relatedPosts?: CollectionEntry<'blog'>[];
}

const { entry, relatedPosts = [] } = Astro.props;
const readingMinutes = getReadingMinutes(entry);
const pageTitle = `${entry.data.title} | 刘强 | usgpt.us`;
const pageDescription = entry.data.description;
---

<BaseLayout title={pageTitle} description={pageDescription} currentPath={`/blog/${entry.id}/`}>
  <article class="container article-shell">
    <header class="panel article-hero">
      <span class="eyebrow">文章</span>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
      <div class="meta-row">
        <span>{formatDate(entry.data.pubDate)}</span>
        {entry.data.updatedDate && <span>更新于 {formatDate(entry.data.updatedDate)}</span>}
        <span>{readingMinutes} 分钟阅读</span>
      </div>
      <div class="tag-row">
        {entry.data.tags.map((tag) => (
          <a class="chip" href={`/tags/${slugifyTag(tag)}/`}>#{tag}</a>
        ))}
      </div>
    </header>

    <div class="two-column article-grid">
      <section class="panel article-main">
        <div class="prose">
          <slot />
        </div>
      </section>

      <aside class="article-side">
        <section class="panel side-card">
          <span class="eyebrow">文章信息</span>
          <div class="side-list">
            <div>
              <strong>发布时间</strong>
              <span>{formatDate(entry.data.pubDate)}</span>
            </div>
            <div>
              <strong>阅读时长</strong>
              <span>{readingMinutes} 分钟</span>
            </div>
            <div>
              <strong>分类标签</strong>
              <span>{entry.data.tags.join(' / ')}</span>
            </div>
          </div>
        </section>

        {
          relatedPosts.length > 0 && (
            <section class="panel side-card">
              <span class="eyebrow">继续阅读</span>
              <div class="related-list">
                {relatedPosts.map((post) => (
                  <a href={`/blog/${post.id}/`}>
                    <strong>{post.data.title}</strong>
                    <span>{post.data.description}</span>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </aside>
    </div>

    <div class="comments-block">
      <GiscusComments />
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: 24px;
  }

  .article-hero,
  .article-main,
  .side-card {
    padding: 30px;
  }

  .article-hero h1 {
    margin: 0;
    max-width: 16ch;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2.3rem, 4vw, 4rem);
    line-height: 1.12;
  }

  .lead {
    max-width: 44rem;
    margin: 18px 0 0;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .article-grid {
    align-items: start;
  }

  .article-side {
    display: grid;
    gap: 18px;
  }

  .side-list,
  .related-list {
    display: grid;
    gap: 14px;
  }

  .side-list div,
  .related-list a {
    display: grid;
    gap: 6px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
  }

  .side-list div:first-child,
  .related-list a:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .side-list strong,
  .related-list strong {
    font-size: 0.98rem;
  }

  .side-list span,
  .related-list span {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .comments-block {
    margin-top: 6px;
  }
</style>
