---
import BaseLayout from '../components/BaseLayout.astro';
import GiscusComments from '../components/GiscusComments.astro';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { formatDate, slugifyTag } from '../lib/format';
import { getReadingMinutes } from '../lib/content';

interface Props {
  entry: CollectionEntry<'blog'>;
  relatedPosts?: CollectionEntry<'blog'>[];
  headings?: MarkdownHeading[];
  previousPost?: CollectionEntry<'blog'>;
  nextPost?: CollectionEntry<'blog'>;
}

const { entry, relatedPosts = [], headings = [], previousPost, nextPost } = Astro.props;
const readingMinutes = getReadingMinutes(entry);
const pageTitle = `${entry.data.title} | 刘强的个人工作台`;
const pageDescription = entry.data.description;
const tocHeadings = headings.filter((heading) => heading.depth <= 2);
---

<BaseLayout title={pageTitle} description={pageDescription} currentPath={`/blog/${entry.id}/`}>
  <article class="article-shell">
    <header class="panel article-hero">
      <div class="crumbs">
        <a href="/">首页</a>
        <span>/</span>
        <a href="/blog">文章</a>
        <span>/</span>
        <span>{entry.data.title}</span>
      </div>
      <h1>{entry.data.title}</h1>
      <p class="lead">{entry.data.description}</p>
      <div class="article-meta">
        <span>{formatDate(entry.data.pubDate)}</span>
        {entry.data.updatedDate && <span>更新于 {formatDate(entry.data.updatedDate)}</span>}
        <span>{readingMinutes} 分钟阅读</span>
      </div>
      <div class="tag-row">
        {entry.data.tags.map((tag) => (
          <a class="chip" href={`/tags/${slugifyTag(tag)}/`}>#{tag}</a>
        ))}
      </div>
    </header>

    <div class="article-layout">
      <section class="article-main">
        <div class="prose">
          <slot />
        </div>

        {(previousPost || nextPost) && (
          <div class="pager">
            {previousPost ? (
              <a href={`/blog/${previousPost.id}/`}>← 上一篇：{previousPost.data.title}</a>
            ) : (
              <span></span>
            )}
            {nextPost ? <a href={`/blog/${nextPost.id}/`}>下一篇：{nextPost.data.title} →</a> : <span></span>}
          </div>
        )}
      </section>

      <aside class="article-side">
        <section class="panel side-card">
          <h2>目录</h2>
          <div class="toc-list">
            {
              tocHeadings.length > 0 ? (
                tocHeadings.map((heading) => <a href={`#${heading.slug}`}>{heading.text}</a>)
              ) : (
                <span>这篇文章没有目录。</span>
              )
            }
          </div>
        </section>

        <section class="panel side-card">
          <span class="eyebrow">文章信息</span>
          <div class="side-list">
            <div>
              <strong>发布时间</strong>
              <span>{formatDate(entry.data.pubDate)}</span>
            </div>
            <div>
              <strong>阅读时长</strong>
              <span>{readingMinutes} 分钟</span>
            </div>
            <div>
              <strong>分类标签</strong>
              <span>{entry.data.tags.join(' / ')}</span>
            </div>
          </div>
        </section>

        {
          relatedPosts.length > 0 && (
            <section class="panel side-card">
              <span class="eyebrow">继续阅读</span>
              <div class="related-list">
                {relatedPosts.map((post) => (
                  <a href={`/blog/${post.id}/`}>
                    <strong>{post.data.title}</strong>
                    <span>{post.data.description}</span>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </aside>
    </div>

    <div class="comments-block">
      <GiscusComments />
    </div>
  </article>
</BaseLayout>

<style>
  .article-shell {
    display: grid;
    gap: 18px;
  }

  .article-hero {
    padding: 24px 26px;
  }

  .article-hero h1 {
    margin: 14px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 4vw, 2.9rem);
    line-height: 1.28;
  }

  .lead {
    margin: 14px 0 0;
    color: var(--text-soft);
    line-height: 1.82;
  }

  .crumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--text-soft);
    font-size: 0.82rem;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 24px;
    color: #8a7561;
    font-size: 0.94rem;
  }

  .article-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 260px;
    gap: 20px;
    align-items: start;
  }

  .article-side {
    display: grid;
    gap: 16px;
    position: sticky;
    top: 86px;
  }

  .toc-list {
    display: grid;
    gap: 14px;
    margin-top: 20px;
  }

  .toc-list a,
  .toc-list span {
    color: var(--text-soft);
    line-height: 1.8;
    font-size: 0.96rem;
  }

  .toc-list a:hover {
    color: var(--accent-deep);
  }

  .article-main {
    padding: 26px 28px;
    border-radius: var(--radius-lg);
    background: #fff;
    border: 1px solid var(--line);
    box-shadow: var(--shadow);
  }

  .side-list,
  .related-list {
    display: grid;
    gap: 14px;
  }

  .side-list div,
  .related-list a {
    display: grid;
    gap: 6px;
    padding: 16px 0;
    border-top: 1px solid var(--line);
  }

  .side-list div:first-child,
  .related-list a:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .side-list strong,
  .related-list strong {
    font-size: 0.98rem;
  }

  .side-list span,
  .related-list span {
    color: var(--text-soft);
    line-height: 1.8;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
  }

  .side-card {
    padding: 18px;
  }

  .side-card h2 {
    margin: 0 0 14px;
    font-size: 1rem;
  }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 42px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .pager a,
  .pager span {
    color: var(--accent-deep);
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.7;
  }

  .comments-block {
    margin-top: 24px;
  }

  @media (max-width: 1100px) {
    .article-layout {
      grid-template-columns: 1fr;
    }

    .article-side {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .article-hero {
      padding: 20px;
    }

    .article-hero h1 {
      font-size: clamp(1.9rem, 9vw, 2.5rem);
    }

    .lead {
      font-size: 1rem;
    }

    .article-main,
    .side-card {
      padding: 18px;
    }

    .pager {
      flex-direction: column;
    }
  }
</style>
