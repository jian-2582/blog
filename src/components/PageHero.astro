---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  actions?: { href: string; label: string; variant?: 'primary' | 'secondary' }[];
  aside?: { label: string; value: string }[];
}

const { eyebrow, title, description, actions = [], aside = [] } = Astro.props;
---

<section class="page-hero panel">
  <div class="page-hero-main">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="page-hero-title">{title}</h1>
    <p class="page-hero-copy">{description}</p>
    {
      actions.length > 0 && (
        <div class="page-hero-actions">
          {actions.map((action) => (
            <a
              class:list={[
                'button',
                action.variant === 'secondary' ? 'button-secondary' : 'button-primary',
              ]}
              href={action.href}
            >
              {action.label}
            </a>
          ))}
        </div>
      )
    }
  </div>

  {
    aside.length > 0 && (
      <aside class="page-hero-side">
        {aside.map((item) => (
          <article class="page-hero-metric">
            <small>{item.label}</small>
            <strong>{item.value}</strong>
          </article>
        ))}
      </aside>
    )
  }
</section>

<style>
  .page-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.22fr) minmax(320px, 0.78fr);
    gap: 34px;
    padding: 34px;
    background: linear-gradient(180deg, rgba(255, 251, 246, 0.88), rgba(250, 244, 236, 0.9));
  }

  .page-hero-title {
    margin: 18px 0 0;
    max-width: 11ch;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2.6rem, 5vw, 4rem);
    line-height: 1.12;
    letter-spacing: -0.03em;
  }

  .page-hero-copy {
    max-width: 42rem;
    margin: 24px 0 0;
    color: var(--text-soft);
    font-size: 1.08rem;
    line-height: 1.9;
  }

  .page-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  .page-hero-side {
    display: grid;
    gap: 14px;
    align-content: start;
  }

  .page-hero-metric {
    padding: 20px 22px;
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(222, 203, 183, 0.8);
  }

  .page-hero-metric small {
    display: block;
    margin-bottom: 8px;
    color: #8c765f;
    font-size: 0.84rem;
  }

  .page-hero-metric strong {
    font-size: 1.12rem;
  }

  @media (max-width: 960px) {
    .page-hero {
      grid-template-columns: 1fr;
      padding: 28px 24px;
    }

    .page-hero-title {
      max-width: none;
      font-size: clamp(2.2rem, 9vw, 3.1rem);
    }
  }
</style>
