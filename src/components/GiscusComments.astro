---
const repo = import.meta.env.PUBLIC_COMMENT_REPO || 'jian-2582/blog';
---

<section class="panel comments-wrap">
  <div class="comments-head">
    <span class="eyebrow">评论</span>
    <h2 class="section-title">讨论与反馈</h2>
  </div>
  <div class="utterances-host">
    <script
      src="https://utteranc.es/client.js"
      repo={repo}
      issue-term="pathname"
      label="评论"
      theme="github-light"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

<style>
  .comments-wrap {
    padding: 32px;
  }

  .comments-head {
    margin-bottom: 24px;
  }

  .utterances-host {
    min-height: 220px;
  }
</style>
