---
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/700.css';
import '@fontsource/noto-serif-sc/700.css';
import Analytics from './Analytics.astro';
import { siteConfig } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  currentPath?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.seo.defaultOg,
  currentPath = Astro.url.pathname,
} = Astro.props;

const canonical = new URL(currentPath, siteConfig.siteUrl).toString();
const ogImage = new URL(image, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f1e8dd" />
    <slot name="head" />
  </head>
  <body>
    <div class="page-shell">
      <div class="shell-blur shell-blur-a"></div>
      <div class="shell-blur shell-blur-b"></div>
      <div class="site-frame">
        <div class="site-inner">
          <header class="site-header">
            <a class="brand" href="/">
              <span class="brand-mark">L</span>
              <span class="brand-text">
                <strong>{siteConfig.author}</strong>
                <small>人工智能 / 自动化 / 个人网站</small>
              </span>
            </a>
            <nav class="site-nav" aria-label="主导航">
              {
                siteConfig.navigation.map((item) => (
                  <a class:list={[Astro.url.pathname === item.href && 'is-active']} href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </header>

          <main>
            <slot />
          </main>

          <footer class="site-footer">
            <div>
              <p class="footer-title">{siteConfig.title}</p>
              <p class="footer-copy">{siteConfig.intro}</p>
            </div>
            <div class="footer-links">
              {siteConfig.social.map((item) => (
                <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
              ))}
              <a href="/rss.xml">订阅更新</a>
            </div>
          </footer>
        </div>
      </div>
    </div>
    <Analytics />
    <slot name="scripts" />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f8f4ee;
    --bg-soft: #f1e8dd;
    --paper: rgba(255, 251, 245, 0.9);
    --paper-strong: rgba(255, 253, 249, 0.96);
    --line: rgba(107, 78, 47, 0.12);
    --line-strong: rgba(107, 78, 47, 0.2);
    --text: #1d1712;
    --text-soft: rgba(29, 23, 18, 0.66);
    --accent: #c46e34;
    --accent-deep: #8c4618;
    --accent-soft: rgba(196, 110, 52, 0.12);
    --shadow: 0 26px 72px rgba(85, 57, 30, 0.08);
    --radius-xl: 32px;
    --radius-lg: 24px;
    --radius-md: 16px;
    --site-width: min(1500px, calc(100vw - 34px));
    --content-width: min(1360px, calc(100vw - 72px));
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    font-family: 'Noto Sans SC', sans-serif;
    color: var(--text);
    background:
      radial-gradient(circle at 18% 8%, rgba(116, 136, 113, 0.14), transparent 18%),
      radial-gradient(circle at 84% 10%, rgba(193, 118, 64, 0.16), transparent 22%),
      linear-gradient(180deg, #f5eee5 0%, #f3ece4 45%, #ede4d8 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .page-shell {
    position: relative;
    min-height: 100vh;
    padding: 32px 0;
  }

  .site-frame {
    width: var(--site-width);
    margin: 0 auto;
    border-radius: 40px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.56), rgba(255, 255, 255, 0.32));
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 28px 90px rgba(76, 48, 22, 0.1);
    overflow: hidden;
    position: relative;
  }

  .site-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        124deg,
        transparent 0,
        transparent 49%,
        rgba(185, 142, 103, 0.04) 49%,
        rgba(185, 142, 103, 0.04) 51%,
        transparent 51%,
        transparent 100%
      );
    pointer-events: none;
  }

  .site-inner {
    width: var(--content-width);
    margin: 0 auto;
    position: relative;
  }

  .shell-blur {
    position: fixed;
    z-index: -1;
    border-radius: 999px;
    filter: blur(20px);
    opacity: 0.75;
    pointer-events: none;
  }

  .shell-blur-a {
    top: 120px;
    left: 6%;
    width: 260px;
    height: 260px;
    background: rgba(130, 147, 121, 0.16);
  }

  .shell-blur-b {
    top: 180px;
    right: 8%;
    width: 320px;
    height: 320px;
    background: rgba(199, 134, 82, 0.16);
  }

  .site-header {
    position: sticky;
    top: 18px;
    z-index: 30;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 34px;
    padding: 18px 22px;
    border-radius: 999px;
    background: rgba(255, 248, 240, 0.88);
    border: 1px solid rgba(229, 210, 191, 0.92);
    backdrop-filter: blur(18px);
    box-shadow: 0 10px 28px rgba(96, 63, 31, 0.04);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 16px;
    background: linear-gradient(135deg, #c07b45, #7d431d);
    color: #fff8f0;
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    box-shadow: 0 10px 24px rgba(134, 75, 31, 0.22);
  }

  .brand-text {
    display: grid;
    gap: 3px;
    min-width: 0;
  }

  .brand-text strong {
    font-size: 1rem;
    letter-spacing: 0.04em;
  }

  .brand-text small {
    color: #806b58;
    font-size: 0.8rem;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: 8px;
  }

  .site-nav a {
    padding: 10px 14px;
    border-radius: 999px;
    color: #785f49;
    font-size: 0.92rem;
    font-weight: 600;
    transition: 180ms ease;
  }

  .site-nav a:hover,
  .site-nav a.is-active {
    color: var(--text);
    background: rgba(255, 255, 255, 0.88);
  }

  main {
    padding: 40px 0 72px;
  }

  .site-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    padding: 0 0 52px;
    color: #8c7661;
  }

  .footer-title {
    margin: 0 0 10px;
    color: var(--text);
    font-weight: 700;
  }

  .footer-copy {
    margin: 0;
    max-width: 44rem;
    line-height: 1.8;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-links a:hover {
    color: var(--accent-deep);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #8f5f3c;
    font-size: 0.86rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow::before {
    content: '';
    width: 24px;
    height: 1px;
    background: currentColor;
  }

  .section-title {
    margin: 18px 0 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2rem, 3.2vw, 3.5rem);
    line-height: 1.16;
    letter-spacing: -0.03em;
  }

  .section-copy {
    max-width: 48rem;
    margin: 16px 0 0;
    color: var(--text-soft);
    font-size: 1.18rem;
    line-height: 1.85;
  }

  .panel {
    background: var(--paper);
    border: 1px solid rgba(228, 212, 196, 0.95);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
  }

  .grid {
    display: grid;
    gap: 22px;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 999px;
    background: #f2e3d3;
    color: #8b5a36;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    color: #8c7661;
    font-size: 0.92rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 15px 24px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.95rem;
    font-weight: 700;
    transition: 180ms ease;
  }

  .button-primary {
    color: #fff8ef;
    background: linear-gradient(135deg, #bd7844, #82431c);
    box-shadow: 0 12px 28px rgba(135, 76, 31, 0.2);
  }

  .button-secondary {
    background: rgba(255, 255, 255, 0.78);
    border-color: rgba(207, 183, 159, 0.78);
  }

  .button-primary:hover,
  .button-secondary:hover {
    transform: translateY(-1px);
  }

  .card-link {
    display: grid;
    gap: 18px;
    padding: 28px;
    border-radius: var(--radius-lg);
    background: var(--paper-strong);
    border: 1px solid rgba(228, 212, 196, 0.95);
    box-shadow: var(--shadow);
    transition: 180ms ease;
  }

  .card-link:hover {
    transform: translateY(-2px);
    border-color: rgba(177, 120, 76, 0.24);
  }

  .card-link h2,
  .card-link h3 {
    margin: 0;
    font-family: 'Noto Serif SC', serif;
    font-size: 2rem;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .card-link p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.88;
    font-size: 1rem;
  }

  .prose {
    color: #30241b;
    font-size: 1.18rem;
    line-height: 1.9;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2.4rem;
    margin-bottom: 1rem;
    font-family: 'Noto Serif SC', serif;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .prose h2 {
    font-size: 2.4rem;
  }

  .prose h3 {
    font-size: 1.9rem;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 0 0 1.5rem;
  }

  .prose code {
    padding: 0.15rem 0.42rem;
    border-radius: 8px;
    background: rgba(113, 72, 38, 0.08);
    font-size: 0.92em;
  }

  .prose pre {
    overflow-x: auto;
    margin: 1.8rem 0;
    padding: 1.45rem 1.6rem;
    border-radius: 18px;
    background: #251d19;
    color: #f7efe8;
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .prose blockquote {
    padding: 0.2rem 0 0.2rem 1.1rem;
    border-left: 3px solid var(--accent);
    color: #7b6653;
  }

  .prose ul,
  .prose ol {
    padding-left: 1.4rem;
  }

  @media (max-width: 1100px) {
    .site-header {
      position: static;
      flex-direction: column;
      align-items: stretch;
      border-radius: 28px;
    }

    .site-nav {
      justify-content: flex-start;
    }
  }

  @media (max-width: 720px) {
    :root {
      --site-width: calc(100vw - 16px);
      --content-width: calc(100vw - 36px);
      --radius-xl: 26px;
      --radius-lg: 20px;
      --radius-md: 14px;
    }

    body {
      background:
        radial-gradient(circle at 14% 4%, rgba(116, 136, 113, 0.12), transparent 18%),
        linear-gradient(180deg, #f5eee5 0%, #f1e8dd 100%);
    }

    .page-shell {
      padding: 8px 0;
    }

    .site-frame {
      border-radius: 26px;
    }

    .site-inner {
      width: calc(100vw - 30px);
    }

    .site-header {
      margin-top: 16px;
      padding: 16px;
    }

    .brand-text small {
      font-size: 0.74rem;
    }

    main {
      padding: 24px 0 50px;
    }

    .section-title {
      font-size: clamp(1.9rem, 9vw, 2.7rem);
    }

    .section-copy {
      font-size: 1rem;
    }

    .card-link {
      padding: 22px;
    }

    .card-link h2,
    .card-link h3 {
      font-size: 1.55rem;
    }

    .prose {
      font-size: 1rem;
      line-height: 1.9;
    }

    .prose h2 {
      font-size: 1.8rem;
    }

    .prose h3 {
      font-size: 1.45rem;
    }

    .site-footer {
      padding-bottom: 34px;
    }
  }
</style>
