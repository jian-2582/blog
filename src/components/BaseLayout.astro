---
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/700.css';
import '@fontsource/noto-serif-sc/700.css';
import Analytics from './Analytics.astro';
import { siteConfig } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  currentPath?: string;
}

const {
  title = siteConfig.title,
  description = siteConfig.description,
  image = siteConfig.seo.defaultOg,
  currentPath = Astro.url.pathname,
} = Astro.props;

const canonical = new URL(currentPath, siteConfig.siteUrl).toString();
const ogImage = new URL(image, siteConfig.siteUrl).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f5f5f5" />
    <slot name="head" />
  </head>
  <body>
    <div class="topline"></div>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href="/">
          <span class="brand-mark">L</span>
          <span class="brand-copy">
            <strong>{siteConfig.author}</strong>
            <small>个人博客</small>
          </span>
        </a>
        <nav class="site-nav" aria-label="主导航">
          {
            siteConfig.navigation.map((item) => (
              <a class:list={[Astro.url.pathname === item.href && 'is-active']} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="site-main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>{siteConfig.title} · 持续记录人工智能、自动化与个人网站实践</p>
        <div class="footer-links">
          {siteConfig.social.map((item) => (
            <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
          ))}
          <a href="/rss.xml">订阅更新</a>
        </div>
      </div>
    </footer>

    <Analytics />
    <slot name="scripts" />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f5f5f5;
    --panel: #ffffff;
    --panel-soft: #fafafa;
    --line: #e5e5e5;
    --line-strong: #d6d6d6;
    --text: #1f1f1f;
    --text-soft: #666666;
    --accent: #1177bb;
    --accent-soft: rgba(17, 119, 187, 0.1);
    --shadow: 0 4px 16px rgba(31, 31, 31, 0.05);
    --radius-lg: 14px;
    --radius-md: 10px;
    --container: min(1240px, calc(100vw - 32px));
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-width: 320px;
    color: var(--text);
    font-family: 'Noto Sans SC', sans-serif;
    background: var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .topline {
    height: 4px;
    background: linear-gradient(90deg, #2d7dbf, #68a9db 50%, #2d7dbf 100%);
  }

  .container {
    width: var(--container);
    margin: 0 auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
    background: #fff;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 68px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: #8b4f24;
    color: #fff;
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
  }

  .brand-copy {
    display: grid;
    gap: 2px;
  }

  .brand-copy strong {
    font-size: 1rem;
  }

  .brand-copy small {
    color: var(--text-soft);
    font-size: 0.74rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
  }

  .site-nav a {
    position: relative;
    padding: 8px 0;
    color: #444;
    font-size: 0.95rem;
    font-weight: 500;
  }

  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 2px;
    height: 2px;
    background: transparent;
    transition: 160ms ease;
  }

  .site-nav a:hover,
  .site-nav a.is-active {
    color: var(--accent);
  }

  .site-nav a:hover::after,
  .site-nav a.is-active::after {
    background: var(--accent);
  }

  .site-main {
    padding: 22px 0 44px;
  }

  .site-footer {
    border-top: 1px solid var(--line);
    background: #fff;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 68px;
    color: var(--text-soft);
    font-size: 0.92rem;
  }

  .footer-inner p {
    margin: 0;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .eyebrow::before {
    content: '';
    width: 18px;
    height: 1px;
    background: currentColor;
  }

  .section-title {
    margin: 0;
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.25;
  }

  .section-copy {
    margin: 12px 0 0;
    color: var(--text-soft);
    line-height: 1.9;
  }

  .panel {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    color: var(--text-soft);
    font-size: 0.86rem;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1px solid transparent;
    font-size: 0.88rem;
    font-weight: 700;
    transition: 160ms ease;
  }

  .button-primary {
    color: #fff;
    background: var(--accent);
  }

  .button-secondary {
    color: var(--accent);
    background: #fff;
    border-color: #cfd9e2;
  }

  .card-link {
    display: grid;
    gap: 12px;
    padding: 18px 20px;
    border-radius: var(--radius-md);
    background: #fff;
    border: 1px solid var(--line);
    transition: 160ms ease;
  }

  .card-link:hover {
    border-color: #d1dde7;
    box-shadow: 0 8px 20px rgba(17, 119, 187, 0.05);
  }

  .card-link h2,
  .card-link h3 {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.45;
    font-family: 'Noto Serif SC', serif;
  }

  .card-link p {
    margin: 0;
    color: var(--text-soft);
    line-height: 1.82;
    font-size: 0.95rem;
  }

  .prose {
    color: #2b2b2b;
    line-height: 1.95;
    font-size: 1.04rem;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2.3rem;
    margin-bottom: 1rem;
    font-family: 'Noto Serif SC', serif;
    line-height: 1.3;
  }

  .prose h2 {
    font-size: 2rem;
  }

  .prose h3 {
    font-size: 1.5rem;
  }

  .prose p,
  .prose ul,
  .prose ol,
  .prose blockquote {
    margin: 0 0 1.4rem;
  }

  .prose code {
    padding: 0.12rem 0.4rem;
    border-radius: 6px;
    background: #f2f4f7;
    font-size: 0.92em;
  }

  .prose pre {
    overflow-x: auto;
    margin: 1.6rem 0;
    padding: 1.1rem 1.2rem;
    border-radius: 10px;
    background: #21252b;
    color: #f7f7f7;
    font-size: 0.92rem;
    line-height: 1.7;
  }

  .prose blockquote {
    padding-left: 1rem;
    border-left: 3px solid #d8b08a;
    color: #666;
  }

  @media (max-width: 860px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 12px 0;
    }

    .site-nav {
      gap: 14px;
    }
  }

  @media (max-width: 720px) {
    :root {
      --container: calc(100vw - 24px);
    }

    .site-main {
      padding: 16px 0 30px;
    }

    .footer-inner {
      padding: 14px 0;
      align-items: flex-start;
    }

    .card-link {
      padding: 16px;
    }
  }
</style>
