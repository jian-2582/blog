{
  email hi@usgpt.us
}

www.usgpt.us {
  tls /etc/letsencrypt/live/usgpt.us/fullchain.pem /etc/letsencrypt/live/usgpt.us/privkey.pem
  redir https://usgpt.us{uri} permanent
}

usgpt.us {
  tls /etc/letsencrypt/live/usgpt.us/fullchain.pem /etc/letsencrypt/live/usgpt.us/privkey.pem
  encode zstd gzip
  root * /srv/www/site/current

  @static {
    path *.css *.js *.mjs *.svg *.png *.jpg *.jpeg *.webp *.avif *.ico *.woff *.woff2
  }
  header @static Cache-Control "public, max-age=31536000, immutable"

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  try_files {path} {path}/
  file_server

  handle_errors {
    @404 expression {err.status_code} == 404
    rewrite @404 /404.html
    file_server
  }
}

analytics.usgpt.us {
  tls /etc/letsencrypt/live/usgpt.us/fullchain.pem /etc/letsencrypt/live/usgpt.us/privkey.pem
  encode zstd gzip
  reverse_proxy 127.0.0.1:3001
}

admin.usgpt.us {
  encode zstd gzip
  reverse_proxy 127.0.0.1:4322
}
